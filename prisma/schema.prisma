generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String?
  phone     String?
  email     String?   @unique
  createdAt DateTime  @default(now())
  leads     Lead[]
  projects  Project[]
}

model Template {
  id              String    @id @default(cuid())
  name            String
  category        String
  previewImageUrl String
  defaultConfig   String
  projects        Project[]
}

model Project {
  id          String    @id @default(cuid())
  userId      String
  templateId  String
  storeName   String
  tagline     String?
  logoUrl     String?
  category    String
  themeColor  String    @default("#3B82F6")
  slug        String    @unique
  status      String    @default("draft")
  storeConfig String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  leads       Lead[]
  products    Product[]
  template    Template  @relation(fields: [templateId], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@index([slug])
}

model Product {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  price       Float
  imageUrl    String?
  description String?
  sortOrder   Int     @default(0)
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Lead {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  name      String?
  phone     String?
  email     String?
  message   String?
  status    String   @default("baru")
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([status])
}
